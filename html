<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<title>Guerra de Foguetes no Universo</title>
<style>
  body {
    margin: 0;
    background: #000011;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    font-family: Arial, sans-serif;
  }
  canvas {
    border: 4px solid #00ccff;
    border-radius: 10px;
    box-shadow: 0 0 30px #00ccff;
  }
</style>
</head>
<body>

<canvas id="game" width="800" height="600"></canvas>

<script>
// ==================== JOGO GUERRA DE FOGUETES ====================
const canvas = document.getElementById('game');
const ctx = canvas.getContext('2d');

const WIDTH = 800;
const HEIGHT = 600;

let player = { x: 400, y: 530, w: 50, h: 45, speed: 6 };
let bullets = [];
let enemies = [];
let enemyBullets = [];
let particles = [];
let stars = [];
let score = 0;
let lives = 3;
let gameOver = false;
let lastShot = 0;
const SHOOT_COOLDOWN = 280;

let keys = {};

// ==================== CRIAR ESTRELAS DO UNIVERSO ====================
function initStars() {
  stars = [];
  for (let i = 0; i < 350; i++) {
    stars.push({
<grok-card data-id="F6Dkl" data-type="generated_image_card" data-plain-type="render_generated_image"  data-arg-layout="block"  data-arg-orientation="landscape" ></grok-card>      x: Math.random() * WIDTH,
      y: Math.random() * HEIGHT,
      size: Math.random() * 2.2 + 0.8,
      color: Math.random() > 0.85 ? '#aaddff' : (Math.random() > 0.7 ? '#ffddaa' : '#ffffff')
    });
  }
}

// ==================== DESENHAR FUNDO DO UNIVERSO ====================
function drawBackground() {
  // Espaço escuro
  ctx.fillStyle = '#000011';
  ctx.fillRect(0, 0, WIDTH, HEIGHT);

  // Nebulosas coloridas (universo bonito)
  ctx.fillStyle = 'rgba(120, 60, 200, 0.12)';
  ctx.beginPath();
  ctx.arc(180, 140, 140, 0, Math.PI * 2);
  ctx.fill();

  ctx.fillStyle = 'rgba(60, 160, 220, 0.1)';
  ctx.beginPath();
  ctx.arc(620, 380, 170, 0, Math.PI * 2);
  ctx.fill();

  ctx.fillStyle = 'rgba(200, 80, 120, 0.08)';
  ctx.beginPath();
  ctx.arc(400, 200, 110, 0, Math.PI * 2);
  ctx.fill();

  // Estrelas piscando
  const time = Date.now() / 280;
  for (let star of stars) {
    const alpha = 0.55 + Math.sin(time + star.x * 0.008) * 0.38;
    ctx.globalAlpha = alpha;
    ctx.fillStyle = star.color;
    ctx.fillRect(star.x, star.y, star.size, star.size);
  }
  ctx.globalAlpha = 1;
}

// ==================== DESENHAR NAVE DO JOGADOR ====================
function drawPlayer() {
  const px = player.x;
  const py = player.y;
  const w = player.w;
  const h = player.h;

  // Corpo principal da nave (formato de foguete)
  ctx.fillStyle = '#00ccff';
  ctx.beginPath();
  ctx.moveTo(px, py - h / 2);
  ctx.lineTo(px - w / 2, py + h / 2 - 8);
  ctx.lineTo(px + w / 2, py + h / 2 - 8);
  ctx.closePath();
  ctx.fill();

  // Corpo inferior
  ctx.fillStyle = '#0099cc';
  ctx.fillRect(px - w / 3, py - 8, w * 2 / 3, h / 2 + 8);

  // Cabine
  ctx.fillStyle = '#aaffff';
  ctx.beginPath();
  ctx.arc(px, py - 8, 9, 0, Math.PI * 2);
  ctx.fill();

  // Asas laterais
  ctx.fillStyle = '#ffaa00';
  ctx.beginPath();
  ctx.moveTo(px - w / 2, py + h / 2 - 8);
  ctx.lineTo(px - w / 2 - 18, py + h / 2 + 8);
  ctx.lineTo(px - w / 2 + 3, py + h / 2 - 3);
  ctx.closePath();
  ctx.fill();

  ctx.beginPath();
  ctx.moveTo(px + w / 2, py + h / 2 - 8);
  ctx.lineTo(px + w / 2 + 18, py + h / 2 + 8);
  ctx.lineTo(px + w / 2 - 3, py + h / 2 - 3);
  ctx.closePath();
  ctx.fill();

  // Chamas do motor
  ctx.fillStyle = '#ff6600';
  ctx.fillRect(px - 9, py + h / 2 - 3, 18, 14);
  ctx.fillStyle = '#ffff00';
  ctx.fillRect(px - 5, py + h / 2 + 5, 10, 10);
}

// ==================== DESENHAR INIMIGO ====================
function drawEnemy(e) {
  const ex = e.x;
  const ey = e.y;
  const ew = e.w;
  const eh = e.h;

  // Corpo do inimigo (nave vermelha)
  ctx.fillStyle = '#ff2255';
  ctx.beginPath();
  ctx.moveTo(ex, ey + eh / 2);
  ctx.lineTo(ex - ew / 2, ey - eh / 2 + 6);
  ctx.lineTo(ex + ew / 2, ey - eh / 2 + 6);
  ctx.closePath();
  ctx.fill();

  ctx.fillStyle = '#aa1122';
  ctx.fillRect(ex - ew / 3, ey - eh / 2 + 4, ew * 2 / 3, eh / 2);

  // Luzes / olhos
  ctx.fillStyle = '#ffff00';
  ctx.fillRect(ex - 11, ey - 3, 7, 7);
  ctx.fillRect(ex + 4, ey - 3, 7, 7);

  // Antena
  ctx.strokeStyle = '#ffffff';
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.moveTo(ex, ey - eh / 2 + 4);
  ctx.lineTo(ex, ey - eh / 2 - 12);
  ctx.stroke();
  ctx.fillStyle = '#ffaa00';
  ctx.beginPath();
  ctx.arc(ex, ey - eh / 2 - 14, 5, 0, Math.PI * 2);
  ctx.fill();
}

// ==================== CRIAR EXPLOSÃO ====================
function createExplosion(x, y) {
  for (let i = 0; i < 18; i++) {
    particles.push({
      x: x,
      y: y,
      vx: (Math.random() - 0.5) * 5,
      vy: (Math.random() - 0.5) * 5,
      life: 35 + Math.random() * 25,
      color: ['#ffaa00', '#ff5500', '#ffff00', '#ff8800'][Math.floor(Math.random() * 4)]
    });
  }
}

// ==================== VERIFICAR COLISÃO ====================
function collides(a, b) {
  return a.x - a.w / 2 < b.x + b.w / 2 &&
         a.x + a.w / 2 > b.x - b.w / 2 &&
         a.y - a.h / 2 < b.y + b.h / 2 &&
         a.y + a.h / 2 > b.y - b.h / 2;
}

// ==================== CRIAR INIMIGOS ====================
function spawnNewEnemy() {
  if (enemies.length >= 8) return;
  enemies.push({
    x: Math.random() * (WIDTH - 100) + 50,
    y: 40 + Math.random() * 40,
    w: 38,
    h: 32,
    speed: 1.3 + Math.random() * 1.4,
    dir: Math.random() > 0.5 ? 1 : -1
  });
}

function initEnemies() {
  enemies = [];
  for (let i = 0; i < 6; i++) {
    spawnNewEnemy();
  }
}

// ==================== REINICIAR JOGO ====================
function restartGame() {
  player.x = 400;
  player.y = 530;
  bullets = [];
  enemyBullets = [];
  particles = [];
  score = 0;
  lives = 3;
  gameOver = false;
  lastShot = 0;
  initEnemies();
}

// ==================== ATUALIZAR JOGO ====================
function update() {
  if (gameOver) return;

  // Mover jogador
  if (keys['ArrowLeft'] || keys['a'] || keys['A']) player.x -= player.speed;
  if (keys['ArrowRight'] || keys['d'] || keys['D']) player.x += player.speed;
  player.x = Math.max(35, Math.min(WIDTH - 35, player.x));

  // Mover tiros do jogador
  for (let i = bullets.length - 1; i >= 0; i--) {
    bullets[i].y -= bullets[i].speed || 8;
    if (bullets[i].y < -15) bullets.splice(i, 1);
  }

  // Mover tiros dos inimigos
  for (let i = enemyBullets.length - 1; i >= 0; i--) {
    enemyBullets[i].y += enemyBullets[i].speed || 4.5;
    if (enemyBullets[i].y > HEIGHT + 15) enemyBullets.splice(i, 1);
  }

  // Mover inimigos + atirar
  for (let i = enemies.length - 1; i >= 0; i--) {
    let e = enemies[i];
    e.x += e.speed * e.dir;
    if (e.x < 30 || e.x > WIDTH - 30) e.dir *= -1;
    e.y += 0.45;

    if (e.y > HEIGHT - 30) {
      createExplosion(e.x, e.y);
      enemies.splice(i, 1);
      lives--;
      if (lives <= 0) gameOver = true;
      continue;
    }

    // Inimigos atiram (bem divertido!)
    if (Math.random() < 0.007) {
      enemyBullets.push({
        x: e.x,
        y: e.y + 18,
        w: 6,
        h: 14,
        speed: 4.5
      });
    }
  }

  // Colisões: tiros do jogador x inimigos
  for (let i = bullets.length - 1; i >= 0; i--) {
    let hit = false;
    for (let j = enemies.length - 1; j >= 0; j--) {
      if (collides(bullets[i], enemies[j])) {
        createExplosion(enemies[j].x, enemies[j].y);
        bullets.splice(i, 1);
        enemies.splice(j, 1);
        score += 150;
        hit = true;
        if (enemies.length < 5 && Math.random() < 0.85) spawnNewEnemy();
        break;
      }
    }
    if (hit) break;
  }

  // Colisões: tiros inimigos x jogador
  for (let i = enemyBullets.length - 1; i >= 0; i--) {
    if (collides(enemyBullets[i], player)) {
      createExplosion(player.x, player.y);
      enemyBullets.splice(i, 1);
      lives--;
      if (lives <= 0) gameOver = true;
      break;
    }
  }

  // Colisões: inimigos x jogador
  for (let j = enemies.length - 1; j >= 0; j--) {
    if (collides(enemies[j], player)) {
      createExplosion(enemies[j].x, enemies[j].y);
      createExplosion(player.x, player.y);
      enemies.splice(j, 1);
      lives--;
      if (lives <= 0) gameOver = true;
      else player.x = 400;
      break;
    }
  }

  // Atualizar partículas de explosão
  for (let i = particles.length - 1; i >= 0; i--) {
    let p = particles[i];
    p.x += p.vx;
    p.y += p.vy;
    p.vy += 0.06;
    p.life--;
    if (p.life <= 0) particles.splice(i, 1);
  }

  // Se acabarem os inimigos, criar mais
  if (enemies.length === 0) {
    for (let k = 0; k < 6; k++) spawnNewEnemy();
  }
}

// ==================== DESENHAR TUDO ====================
function draw() {
  drawBackground();

  // Partículas (explosões)
  for (let p of particles) {
    ctx.globalAlpha = Math.max(0, p.life / 55);
    ctx.fillStyle = p.color;
    ctx.fillRect(p.x - 2.5, p.y - 2.5, 5, 5);
  }
  ctx.globalAlpha = 1;

  // Inimigos
  for (let e of enemies) {
    drawEnemy(e);
  }

  // Tiros do jogador
  for (let b of bullets) {
    ctx.fillStyle = '#ffff66';
    ctx.fillRect(b.x - b.w / 2, b.y - b.h / 2, b.w, b.h);
    ctx.fillStyle = '#ff8800';
    ctx.fillRect(b.x - 1.5, b.y + b.h / 2, 3, 10);
  }

  // Tiros dos inimigos
  for (let b of enemyBullets) {
    ctx.fillStyle = '#ff4444';
    ctx.fillRect(b.x - b.w / 2, b.y - b.h / 2, b.w, b.h);
    ctx.fillStyle = '#aa0000';
    ctx.fillRect(b.x - 1.5, b.y - b.h / 2 - 10, 3, 10);
  }

  // Jogador
  drawPlayer();

  // Interface (placar)
  ctx.fillStyle = '#ffffff';
  ctx.font = 'bold 24px Arial';
  ctx.fillText('PONTOS: ' + score, 25, 38);
  ctx.fillText('VIDAS: ' + lives, 640, 38);

  // Tela de Game Over
  if (gameOver) {
    ctx.fillStyle = 'rgba(0, 0, 30, 0.88)';
    ctx.fillRect(140, 170, 520, 290);
    ctx.strokeStyle = '#00ffff';
    ctx.lineWidth = 5;
    ctx.strokeRect(140, 170, 520, 290);

    ctx.fillStyle = '#ff3366';
    ctx.font = 'bold 52px Arial';
    ctx.fillText('GAME OVER', 215, 245);

    ctx.fillStyle = '#ffffff';
    ctx.font = '26px Arial';
    ctx.fillText('Pontuação Final: ' + score, 250, 300);
    ctx.fillText('Pressione R para jogar de novo', 195, 350);
    ctx.font = '20px Arial';
    ctx.fillText('Use ← → ou A/D para mover e ESPAÇO para atirar', 165, 390);
  }
}

// ==================== LOOP PRINCIPAL ====================
function gameLoop() {
  update();
  draw();
  requestAnimationFrame(gameLoop);
}

// ==================== CONTROLES ====================
document.addEventListener('keydown', (e) => {
  keys[e.key] = true;

  if (e.key === ' ' && !gameOver) {
    e.preventDefault();
    const now = Date.now();
    if (now - lastShot > SHOOT_COOLDOWN) {
      bullets.push({
        x: player.x,
        y: player.y - 25,
        w: 7,
        h: 16,
        speed: 9
      });
      lastShot = now;
    }
  }

  if ((e.key.toLowerCase() === 'r') && gameOver) {
    restartGame();
  }
});

document.addEventListener('keyup', (e) => {
  keys[e.key] = false;
});

// ==================== INICIAR JOGO ====================
function startGame() {
  initStars();
  initEnemies();
  gameLoop();
}

startGame();
</script>

</body>
</html>
